#!/usr/bin/env perl
use strict;
use warnings;
use Term::ReadLine;
use Term::ANSIColor qw(:constants);
use Data::Dumper;
use feature 'say';

# Configuration
my $history_file = "$ENV{HOME}/.perlon_history";
my $term = Term::ReadLine->new('Perlon');
$term->read_history($history_file) if -f $history_file;

# Define colors for syntax highlighting (used for output and formatting)
my %color_rules = (
    '\b(sub|my|local|our|use|package|if|else|elsif|for|foreach|while)\b' => BOLD . CYAN,
    '\b(print|say|die|warn|eval|shift|push|pop)\b'                        => BOLD . YELLOW,
    '(\$[a-zA-Z_]\w*)'  => BOLD . RED,     # Scalars
    '(\@[a-zA-Z_]\w*)'  => BOLD . BLUE,    # Arrays
    '(\%[a-zA-Z_]\w*)'  => BOLD . MAGENTA, # Hashes
    '(\b\d+\b)'         => BOLD . YELLOW,  # Numbers
    '(".*?"|\'.*?\')'   => GREEN,          # Strings
);

sub highlight {
    my ($text) = @_;
    return "" unless defined $text;
    foreach my $pattern (keys %color_rules) {
        my $color = $color_rules{$pattern};
        $text =~ s/$pattern/$color$1${\RESET}/g;
    }
    return $text;
}

# Setup Data::Dumper for IPython-like output
$Data::Dumper::Indent = 1;
$Data::Dumper::Terse  = 1;
$Data::Dumper::Useqq  = 1;

print BOLD, CYAN, "Perlon 0.2 - IPython for Perl", RESET, "\n";
print "Type 'exit' to quit. Variables persist across lines.\n\n";

my $count = 1;
# We store code in a wrapper to simulate persistence
my $persistent_code = "use feature 'say'; ";

while ( defined (my $line = $term->readline(BOLD . CYAN . "In [$count]: " . RESET)) ) {
    next if $line =~ /^\s*$/;
    
    if ($line =~ /^\s*exit\s*$/) {
        last;
    }

    # Add to ReadLine history
    $term->addhistory($line);

    # Evaluate the code
    # We wrap it in a block and use a trick to keep variables alive
    # For a simple REPL, we append the line to a buffer if it defines things, 
    # or just eval it in the main package.
    my $to_eval = "package main; no strict 'vars'; $line";

    my @result;
    eval {
        local $SIG{__WARN__} = sub { print YELLOW, "Warn: ", RESET, @_; };
        # Evaluate in list context to capture results correctly
        @result = eval $to_eval;
        die $@ if $@;
    };

    if ($@) {
        print RED, "Error: ", RESET, $@;
    } else {
        # IPython-style 'Out' display
        if (defined $result[0]) {
            print BOLD, GREEN, "Out [$count]: ", RESET;
            if (ref($result[0])) {
                print Dumper($result[0]);
            } else {
                say highlight($result[0]);
            }
        }
    }

    $count++;
}

# Cleanup
$term->write_history($history_file);
print BOLD, CYAN, "\nGoodbye!\n", RESET;
